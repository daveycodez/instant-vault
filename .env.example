# InstantDB — get your app ID and admin token at https://instantdb.com/dash
# Public app ID, exposed to the client
VITE_INSTANT_APP_ID=

# Same app ID, used by the Admin SDK on the server
INSTANT_APP_ID=

# InstantDB admin token — keep secret, never expose to the client
INSTANT_ADMIN_TOKEN=

# Secret used to derive the AES-256-GCM key for encrypting stored
# credentials (admin tokens, storage keys) at rest — keep secret
INSTANT_VAULT_SECRET=
